# Or use individual params for local development:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=selta_magic
DB_USER=postgres
DB_PASSWORD=your_password

# Authentication
JWT_SECRET=your_jwt_secret_here_change_in_production

# Stripe
STRIPE_SECRET_KEY=sk_test_your_key_here

# Server
PORT=5174
FRONTEND_URL=http://localhost:8080
