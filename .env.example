# ===== Frontend (Vite) =====
VITE_API_BASE_URL=http://localhost:5174/api
VITE_UPLOAD_URL=http://localhost:5174
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
VITE_APP_ENV=development

# ===== Backend (Server) =====
